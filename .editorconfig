root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{yaml,yml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.sql]
indent_size = 4

[*.{js,ts,json}]
indent_size = 4

[*.{css,scss}]
indent_size = 4

[*.html]
indent_size = 4

[*.svg]
indent_size = 2

[{Makefile,makefile}]
indent_style = tab
